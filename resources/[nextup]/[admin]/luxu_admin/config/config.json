      "enabled": true,
      "account": "luxu-gg",
      "repo": "luxu_locales",
      "branch": "main"
    }
  },

  "inventory": {
    "auto_detect": true,
    "name": "ox_inventory",
    "images_url": "https://cfx-nui-ox_inventory/web/images/%s.png"
  },

  "vehicles": {
    "use_ox_lib_for_mods": false,
    "images_url": "https://docs.fivem.net/vehicles/%s.webp"
  },

  "jail": {
    "enabled": true,
    "jail_cells": [
      { "name": "Cel 1", "coords": { "x": 459.57, "y": -1001.68, "z": 24.9, "w": 266.29 }, "safeRadius": 5.0 },
      { "name": "Cel 2", "coords": { "x": 458.89, "y": -998.03, "z": 24.9, "w": 269.29 }, "safeRadius": 5.0 },
      { "name": "Cel 3", "coords": { "x": 460.5,  "y": -994.34, "z": 24.9, "w": 269.29 }, "safeRadius": 5.0 }
    ]
  },

  "reports": {
    "enabled": true
  },

  "external_web_panel": {
    "enabled": true
  },

  "custom_map": {
    "enabled": false,
    "type": {
      "active": "image",
      "image": {
        "url": "https://imagedelivery.net/xMNIukUvBnTcljSQ6wCsQg/d69bfcd1-773e-489a-201e-6ec358ec6500/MAPS",
        "options": {
          "bounds": [
            [-4000, -5500],
            [8000, 6000]
          ]
        }
      }
    },
    "options": {
      "minZoom": 2,
      "maxZoom": 8,
      "zoom": 2,
      "center": [0, 0],
      "maxBounds": [
        [-4000, -5500],
        [8000, 6000]
      ]
    },
    "color": "rgb(15,168,210)"
  },

  "warnings": {
    "maximum_warnings_until_ban": 3,
    "message_duration_seconds": 15,
    "ban_duration_days": 1,
    "ban_message": "Maximaal aantal waarschuwingen bereikt!"
  },

  "flags": [
    {
      "id": "suspicious",
      "label": "Verdacht",
      "color": "#ff6201"
    },
    {
      "id": "trusted",
      "label": "Vertrouwd",
      "color": "#1e6cf9"
    },
    {
      "id": "streamer",
      "label": "Streamer",
      "color": "#9146ff"
    }
  ],

  "notifications": {
    "staff_login": true
  },

  "commands": {
    "open_panel": {
      "enabled": true,
      "name": "admin",
      "label": "Staffmenu openen",
      "description": "Open het staffmenu",
      "keybind": true,
      "defaultKey": false
    },
    "open_menu": {
      "enabled": true,
      "name": "luxu",
      "description": "Open het snelmenu",
      "keybind": true,
      "defaultKey": false
    },
    "teleport_marker": {
      "enabled": true,
      "name": "tpmarker",
      "description": "Teleporteer naar een markering",
      "keybind": true,
      "defaultKey": false
    },
    "teleport_go_back": {
      "enabled": true,
      "name": "back",
      "description": "Teleporteer terug naar je vorige positie",
      "keybind": true,
      "defaultKey": false,
      "params": [
        {
          "name": "speler",
          "help": "Speler ID (optioneel)",
          "type": "number"
        }
      ]
    },
    "teleport_player": {
      "enabled": true,
      "name": "tpspeler",
      "description": "Teleporteer naar een speler of coördinaten x y z",
      "params": [
        {
          "name": "speler",
          "help": "Speler ID (optioneel) of coördinaten x y z",
          "type": "number"
        }
      ]
    },
    "teleport_bring_player": {
      "enabled": true,
      "name": "bring",
      "description": "Haal een speler naar jou toe",
      "params": [
        {
          "name": "speler",
          "help": "Speler ID",
          "type": "number"
        }
      ]
    },
    "player_report": {
      "enabled": true,
      "name": "report",
      "description": "Open het reportmenu (alle spelers)",
      "keybind": true,
      "defaultKey": false
    },
    "noclip": {
      "enabled": true,
      "name": "noclip",
      "description": "Noclip aan/uit",
      "keybind": true,
      "defaultKey": false
    },
    "spectate": {
      "enabled": true,
      "name": "spectate",
      "description": "Specteer een speler"
    },
    "staff": {
      "enabled": true,
      "name": "staff",
      "description": "Bekijk alle online staffleden"
    },
    "ban": {
      "enabled": true,
      "name": "ban",
      "description": "Ban een speler",
      "params": [
        {
          "name": "speler",
          "help": "Speler ID",
          "type": "number"
        },
        {
          "name": "duur",
          "help": "Duur van de ban (bijv. 1y2d3h4m)",
          "type": "number"
        },
        {
          "name": "reden",
          "help": "Reden voor de ban",
          "type": "string"
        }
      ]
    },
    "sentence": {
      "enabled": true,
      "name": "sentence",
      "description": "Bekijk je resterende celstraf"
    },
    "jail": {
      "enabled": true,
      "name": "jail",
      "description": "Stuur een speler naar de cel",
      "params": [
        {
          "name": "speler",
          "help": "Speler ID",
          "type": "number"
        },
        {
          "name": "duur",
          "help": "Duur van de celstraf (bijv. 1y2d3h4m)",
          "type": "string"
        },
        {
          "name": "reden",
          "help": "Reden voor de celstraf",
          "type": "string"
        }
      ]
    },
    "admincar": {
      "enabled": true,
      "name": "admincar",
      "description": "Geef een speler een voertuig met mods"
    }
  },

  "logs": {
    "enabled": true,
    "max_age_days": 14,
    "tag_discord_user": true,
    "options": {
      "chat_messages": false,
      "player_deaths": true
    }
  },

  "chats": {
    "character_limit": 500,
    "defaul_notification_position": "bottom-right"
  },

  "loop_delays": {
    "coords_update": 10000
  },

  "optimization": {
    "items_db_include_offline_players": false
  },

  "force_resource_shutdowns": [],

  "esx_boss_grades_names": ["boss", "owner"],

  "announcements": {
    "messages": {
      "position": {
        "left": "0%",
        "top": "0%",
        "margin": "1.5rem"
      }
    }
  },

  "brandoff": false,

  "ui": {
    "disable": {
      "player_count": false
    }
  }
}